{
  "name": "fmcord",
  "version": "1.5.0",
  "description": "FMCord - a fast lightweight slash-command Discord music bot with reliable single now-playing panel, 1-second live progress, voice channel status, yt-dlp direct stream URLs, and FFmpeg.",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "libsodium-wrappers": "^0.7.15",
    "opusscript": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
